# Copier vers .env (non versionné) et renseigner les valeurs.

# Supabase (obligatoire en dev / prod)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL publique canonique de l’app (sans chemin métier). À aligner avec Redirect URLs Supabase pour la récupération MDP.
# Production : https://www.coya.pro (ou https://coya.pro selon votre domaine officiel).
# Les liens « mot de passe oublié » redirigent vers : {VITE_SITE_URL}/auth/recovery (route SPA).
# Ne JAMAIS mettre localhost ici sur l’environnement de build production (Vercel) : les liens e-mail
# « mot de passe oublié » utiliseraient localhost et casseraient la récupération après déploiement.
# VITE_SITE_URL=
# Variante explicite uniquement pour les redirections auth (si différent de SITE_URL)
# VITE_AUTH_REDIRECT_URL=

# Logs verbeux (requêtes REST, DataAdapter). Par défaut : uniquement en dev ; sinon mettre à 1.
# VITE_VERBOSE_LOGS=1

# Parc Auto — catalogue véhicule : fusion avec les JSON embarqués si peu de marques en base ou si forcé.
# VITE_VEHICLE_CATALOG_FALLBACK=1
# Seuil (nombre de marques distantes) en dessous duquel la fusion s’active ; défaut dans le code : 50.
# VITE_VEHICLE_CATALOG_FALLBACK_THRESHOLD=50

# --- IA texte (désactivée par défaut) ---
# COYA utilise des traitements déterministes locaux. Aucune clé IA ne doit figurer ici.
# Les clés API (Gemini, Eden AI, Replicate, Stability AI) doivent être configurées dans
# les Supabase Secrets (Dashboard > Edge Functions > Secrets), jamais dans ce fichier.
#   → GEMINI_API_KEY        (Supabase Secret)
#   → EDENAI_API_KEY        (Supabase Secret)
#   → REPLICATE_API_TOKEN   (Supabase Secret)
#   → STABILITY_AI_API_KEY  (Supabase Secret)
# Pour activer les appels cloud via l'Edge Function ai-proxy :
# VITE_ENABLE_EXTERNAL_TEXT_AI=true

# Images génératives (optionnel) — provider utilisé côté client pour choisir le backend
# VITE_IMAGE_API_PROVIDER=replicate
# VITE_ENABLE_IMAGE_AI=true

# --- Cycle workflow / notifications (optionnel) ---
# Par défaut dans le code : les notifications du cycle ne sont PAS écrites en base.
# Mettre à true uniquement si vous voulez persister les alertes workflow dans `notifications`.
VITE_PERSIST_WORKFLOW_NOTIFICATIONS=false

# Intervalle minimum entre deux exécutions du cycle (ms). Défaut code : 6 h.
# Exemple 1 jour : 86400000
VITE_WORKFLOW_AUTOMATION_INTERVAL_MS=21600000

# Fenêtre de déduplication en mémoire avant insert (minutes). Défaut : 10.
VITE_WORKFLOW_NOTIFICATION_DEDUPE_MINUTES=10
